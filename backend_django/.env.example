# Copiar a .env:  copy .env.example .env



DJANGO_SECRET_KEY=change-me-in-production

DJANGO_DEBUG=True

DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost



# PocketBase (OLTP — crimes_220k)

POCKETBASE_URL=http://127.0.0.1:8090

POCKETBASE_ADMIN_EMAIL=admin@crimetrack.local

POCKETBASE_ADMIN_PASSWORD=CrimeTrack_Admin2026!



# Redis (cache Django + Celery broker)

REDIS_URL=redis://127.0.0.1:6379/0

REDIS_CACHE_URL=redis://127.0.0.1:6379/2

CELERY_BROKER_URL=redis://127.0.0.1:6379/0

CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1



# MinIO (Data Lake Parquet particionado)

MINIO_ENDPOINT=http://127.0.0.1:9000

MINIO_ROOT_USER=minioadmin

MINIO_ROOT_PASSWORD=your_minio_password

MINIO_BUCKET=crimetrack-evidence
MINIO_TRANSACTIONAL_PREFIX=datasets/transactional
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_HOURS=12

# Gmail — recuperación de contraseña
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=crimetracksoporte@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password_de_gmail
DEFAULT_FROM_EMAIL=crimetracksoporte@gmail.com

MINIO_STAR_PREFIX=datasets/star

# ETL PocketBase — paginación sin COUNT (skipTotal=1)
ETL_PB_PER_PAGE=500

# Presigned URLs Direct-to-Client (segundos)
MINIO_PRESIGN_TTL_SECONDS=3600

# CORS MinIO (coma-separado; vacío = CORS_ALLOWED_ORIGINS + localhost)
#MINIO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DuckDB ETL streaming (memoria del worker Celery)
ETL_DUCKDB_MEMORY_LIMIT=1GB



