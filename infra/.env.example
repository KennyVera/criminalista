# Copia este archivo a .env y ajusta los valores en tu máquina local.
#   copy .env.example .env

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me

# Bucket que PocketBase usará para archivos pesados (evidencias, PDFs, etc.)
MINIO_BUCKET=crimetrack-evidence
