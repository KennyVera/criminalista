# Copia este archivo a .env y ajusta los valores en tu máquina local.
#   copy .env.example .env

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me

# Bucket que PocketBase usará para archivos pesados (evidencias, PDFs, etc.)
MINIO_BUCKET=crimetrack-evidence
MINIO_TRANSACTIONAL_PREFIX=datasets/transactional
MINIO_STAR_PREFIX=datasets/star

# Celery usa backend_django/.env para POCKETBASE_ADMIN_* (mismo admin que Django).
# Asegúrate de tener backend_django/.env con la contraseña del superusuario de PocketBase.

# --- ClickHouse (capa táctica / estratégica OLAP) — perfil "analytics" ---
# Interno (otros contenedores): clickhouse:8123 (HTTP) / clickhouse:9000 (nativo).
# Host: http://localhost:8123 (HTTP) y localhost:9100 (nativo, para no chocar con MinIO:9000).
CLICKHOUSE_USER=crimetrack
CLICKHOUSE_PASSWORD=crimetrack_ch_2026
CLICKHOUSE_DB=crimetrack_analytics

# --- Airflow (orquestación MinIO -> ClickHouse) — perfil "analytics" ---
# UID del usuario airflow dentro del contenedor (en Linux usa: id -u). En Windows deja 50000.
AIRFLOW_UID=50000
# Fernet key para cifrar conexiones. La default es un placeholder de DEV (¡cámbiala!).
# Generar una real:  python -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AIRFLOW_FERNET_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
AIRFLOW_WEBSERVER_SECRET_KEY=crimetrack-airflow-secret-change-me
# Credenciales del primer usuario admin del webserver de Airflow.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Postgres de metadatos de Airflow (aislado; no se expone al host).
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow
